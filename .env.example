# ============================================================
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env && nano .env
# NUNCA commite o arquivo .env no git!
# ============================================================

# Telegram
TELEGRAM_BOT_TOKEN=seu_token_aqui         # Obter com @BotFather
TELEGRAM_USER_ID=seu_user_id_aqui         # Seu ID numérico do Telegram

# OpenRouter (gratuito em openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx  # Criar conta gratuita

# Opcional: Google AI Studio (Gemini gratuito)
# GOOGLE_AI_API_KEY=AIxxxxxxxxxxxxxxxx

# Opcional: Binance (apenas leitura, para dados de mercado)
# BINANCE_API_KEY=xxxxxxxx
# BINANCE_API_SECRET=xxxxxxxx
