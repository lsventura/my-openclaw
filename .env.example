# ============================================================
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env && nano .env
# NUNCA commite o arquivo .env no git!
# ============================================================

# ── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=seu_token_aqui         # Obter com @BotFather
TELEGRAM_USER_ID=seu_user_id_aqui         # Seu ID numérico (@userinfobot)

# ── OpenRouter (gratuito em openrouter.ai) ───────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx  # Criar conta gratuita

# ── Binance (leitura de mercado + bot de trading) ────────────
BINANCE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
BINANCE_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Solana (crypto bot) ──────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WALLET_PATH=/root/.openclaw/workspace/wallet.json

# ── Opcional: Google AI Studio (Gemini direto) ───────────────
# GOOGLE_AI_API_KEY=AIxxxxxxxxxxxxxxxx

# ── Opcional: PostgreSQL ─────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
