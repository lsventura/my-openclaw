{
  "$schema": "https://openclaw.ai/schema/config.json",
  "version": "1",
  "gateway": {
    "port": 3000,
    "host": "0.0.0.0"
  },
  "telegram": {
    "token": "${TELEGRAM_BOT_TOKEN}",
    "allowed_users": ["${TELEGRAM_USER_ID}"]
  },
  "agents": {
    "defaults": {
      "provider": "openrouter",
      "model": "moonshotai/kimi-k2",
      "memory": {
        "flush_threshold": 20000,
        "context_ttl_minutes": 180,
        "keep_last_assistant": 2,
        "search_mode": "bm25"
      },
      "tools": ["shell", "filesystem", "web_search"]
    },
    "list": [
      {
        "id": "boss",
        "name": "Amora",
        "config_file": "agents/boss.yaml",
        "primary": true
      }
    ]
  },
  "providers": {
    "openrouter": {
      "api_key": "${OPENROUTER_API_KEY}",
      "base_url": "https://openrouter.ai/api/v1",
      "default_model": "moonshotai/kimi-k2",
      "free_models": [
        "moonshotai/kimi-k2",
        "google/gemini-2.0-flash-exp:free",
        "meta-llama/llama-3.3-70b-instruct:free",
        "deepseek/deepseek-chat:free"
      ]
    }
  },
  "workspace": {
    "root": "./workspace",
    "shared": true
  },
  "daemon": {
    "auto_start": true,
    "restart_on_crash": true,
    "log_file": "/var/log/openclaw/openclaw.log"
  }
}
