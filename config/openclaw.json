{
  "$schema": "https://openclaw.ai/schema/config.json",
  "version": "1",

  // ─── Gateway ────────────────────────────────────────────────
  "gateway": {
    "port": 3000,
    "host": "0.0.0.0"
  },

  // ─── Canal Telegram ─────────────────────────────────────────
  // CORREÇÃO: a chave correta é "channels.telegram", não "telegram"
  // e o campo do token é "botToken", não "token"
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "pairing",
      "groups": {
        "*": {
          "requireMention": false
        }
      }
    }
  },

  // ─── Agentes ────────────────────────────────────────────────
  "agents": {
    "defaults": {
      "provider": "openrouter",
      "model": "moonshotai/kimi-k2",
      "memory": {
        "flush_threshold": 40000,
        "context_ttl_minutes": 360,
        "keep_last_assistant": 3,
        "search_mode": "bm25"
      },
      "tools": ["shell", "filesystem", "web_search"],

      // ─── Sandbox com acesso real ───────────────────────────
      // CORREÇÃO: workspaceAccess "rw" e rede "bridge" permitem
      // que o agente leia/escreva no workspace real e acesse internet
      "sandbox": {
        "mode": "all",
        "scope": "agent",
        "workspaceAccess": "rw",
        "docker": {
          "image": "openclaw-sandbox:bookworm-slim",
          "network": "bridge",
          "env": [
            "OPENROUTER_API_KEY",
            "TELEGRAM_BOT_TOKEN",
            "TELEGRAM_USER_ID",
            "BINANCE_API_KEY",
            "BINANCE_API_SECRET"
          ]
        }
      }
    },

    "list": [
      {
        "id": "boss",
        "name": "Amora",
        "config_file": "agents/boss.yaml",
        "primary": true
      },
      {
        "id": "dev",
        "name": "DevBot",
        "config_file": "agents/dev.yaml"
      },
      {
        "id": "finance",
        "name": "FinanceBot",
        "config_file": "agents/finance.yaml"
      },
      {
        "id": "research",
        "name": "ResearchBot",
        "config_file": "agents/research.yaml"
      },
      {
        "id": "life",
        "name": "LifeBot",
        "config_file": "agents/life.yaml"
      }
    ]
  },

  // ─── Providers ──────────────────────────────────────────────
  "providers": {
    "openrouter": {
      "api_key": "${OPENROUTER_API_KEY}",
      "base_url": "https://openrouter.ai/api/v1",
      "default_model": "moonshotai/kimi-k2",
      "free_models": [
        "moonshotai/kimi-k2",
        "google/gemini-2.5-pro-exp-03-25:free",
        "google/gemini-2.0-flash-exp:free",
        "meta-llama/llama-3.3-70b-instruct:free",
        "deepseek/deepseek-chat:free",
        "deepseek/deepseek-r1:free"
      ]
    }
  },

  // ─── Workspace ──────────────────────────────────────────────
  "workspace": {
    "root": "./workspace",
    "shared": true
  },

  // ─── Daemon ─────────────────────────────────────────────────
  "daemon": {
    "auto_start": true,
    "restart_on_crash": true,
    "log_file": "/var/log/openclaw/openclaw.log"
  }
}
